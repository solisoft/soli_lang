/target
node_modules
.dmux/

# LLVM coverage profile artifacts from `cargo test` runs.
*.profraw

# Per-app secrets — never commit (e.g. SOLI_DEPLOY_API_KEY).
.env
.env.*
!.env.sample
!.env.example
# Test-fixture apps must carry their own `.env.test`: the test runner refuses to
# start without one, so a fixture whose file is ignored passes locally and fails
# on a clean checkout with "".env.test file not found". These hold no secrets.
!tests-e2e/*/.env.test
.claude/settings.local.json
tasks*

# codegraph sub-crate build artifacts
/codegraph/target/
/codegraph/Cargo.lock
