# ============================================================================
# Cross-validation against INDEPENDENT reference implementations.
#
# Expected values were produced by:
#   - exclusive XML C14N : Python lxml  (etree.tostring method="c14n" exclusive=True)
#   - RSA-SHA256 PKCS#1v15: Python `cryptography` (key.sign(..., PKCS1v15(), SHA256()))
#
# This guards against the "author graded their own work" risk: the assertions
# below are not my own hand-derived expectations, they are byte-for-byte the
# output of widely-used, independently-maintained libraries.
# ============================================================================

describe("Xml.c14n_exclusive vs lxml", fn() {
    test("simple attribute sorting matches lxml", fn() {
        assert_eq(
            Xml.c14n_exclusive("<doc b='2' a='1'/>"),
            "<doc a=\"1\" b=\"2\"></doc>"
        );
    });

    test("unused ancestor namespace dropped, like lxml", fn() {
        let xml = "<n0:r xmlns:n0=\"http://a\" xmlns:n2=\"http://c\"><n1:e xmlns:n1=\"http://b\">x</n1:e></n0:r>";
        assert_eq(
            Xml.c14n_exclusive(xml),
            "<n0:r xmlns:n0=\"http://a\"><n1:e xmlns:n1=\"http://b\">x</n1:e></n0:r>"
        );
    });

    test("SAML-like: unused ns is pushed DOWN to where it is used (exclusive)", fn() {
        # `saml` is declared on the root but only used by <saml:Issuer>;
        # exclusive c14n renders it on Issuer, not the root. lxml output.
        let xml = "<samlp:Response xmlns:samlp=\"urn:p\" xmlns:saml=\"urn:a\" ID=\"_1\"><saml:Issuer>idp</saml:Issuer><samlp:Status><samlp:StatusCode Value=\"ok\"/></samlp:Status></samlp:Response>";
        assert_eq(
            Xml.c14n_exclusive(xml),
            "<samlp:Response xmlns:samlp=\"urn:p\" ID=\"_1\"><saml:Issuer xmlns:saml=\"urn:a\">idp</saml:Issuer><samlp:Status><samlp:StatusCode Value=\"ok\"></samlp:StatusCode></samlp:Status></samlp:Response>"
        );
    });

    test("default-namespace undeclaration matches lxml", fn() {
        assert_eq(
            Xml.c14n_exclusive("<root xmlns=\"http://a\"><child xmlns=\"\">t</child></root>"),
            "<root xmlns=\"http://a\"><child xmlns=\"\">t</child></root>"
        );
    });

    test("unprefixed attribute sorts before namespaced one, like lxml", fn() {
        assert_eq(
            Xml.c14n_exclusive("<doc xmlns:b=\"http://b\" b:z=\"1\" a=\"2\"></doc>"),
            "<doc xmlns:b=\"http://b\" a=\"2\" b:z=\"1\"></doc>"
        );
    });

    test("InclusiveNamespaces prefix list matches lxml", fn() {
        let xml = "<n0:root xmlns:n0=\"http://a\" xmlns:n2=\"http://c\"><n0:child>t</n0:child></n0:root>";
        assert_eq(
            Xml.c14n_exclusive(xml, "n2"),
            "<n0:root xmlns:n0=\"http://a\" xmlns:n2=\"http://c\"><n0:child>t</n0:child></n0:root>"
        );
    });
});

# 2048-bit key + signature generated by python `cryptography` (file-scope so
# the deferred test() closures can see them).
const N = "";
const E = "010001";
const D = "";
# SHA-256 DigestInfo DER prefix (RFC 8017 §9.2 notes).
const SHA256_DIGESTINFO = "3031300d060960864801650304020105000420";
const EXPECTED_SIG = "";

describe("RSA-SHA256 PKCS#1 v1.5 vs Python cryptography (real 2048-bit key)", fn() {
    test("our modexp + pkcs1_pad reproduce the library's signature byte-for-byte", fn() {
        let digest = Crypto.sha256("<doc>sign me</doc>");
        let digest_info = SHA256_DIGESTINFO + digest;
        let em = Crypto.pkcs1_pad(digest_info, 256);     # 2048-bit key = 256 octets
        let signature = Crypto.modexp(em, D, N);
        assert_eq(signature, EXPECTED_SIG);
    });

    test("verifying the library's signature recovers our DigestInfo", fn() {
        let digest = Crypto.sha256("<doc>sign me</doc>");
        let recovered = Crypto.pkcs1_unpad(Crypto.modexp(EXPECTED_SIG, E, N));
        assert_eq(recovered, SHA256_DIGESTINFO + digest);
    });
});
