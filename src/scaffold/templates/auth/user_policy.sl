# Example policy — generated by `soli generate auth`.
#
# Demonstrates the conventions: admins can do anything; a user can view and
# edit their own record; nobody else can. Every rule guards on `signed_in?`
# first so a guest (nil user) is denied rather than crashing. Copy this file
# to scaffold policies for your own models.

class UserPolicy < ApplicationPolicy
  def index?
    return this.admin?()
  end

  def show?
    return this.owner_or_admin?()
  end

  def update?
    return this.owner_or_admin?()
  end

  def create?
    return this.admin?()
  end

  def destroy?
    return this.admin?()
  end

  def admin?
    return this.signed_in?() && this.user.admin?()
  end

  def owner_or_admin?
    return false unless this.signed_in?()

    return this.user.admin?() || this.user["_key"] == this.record["_key"]
  end
end
