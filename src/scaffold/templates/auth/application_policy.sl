# Authorization policy layer — generated by `soli generate auth`.
#
# A policy is a class named "<Model>Policy" (e.g. PostPolicy for a Post
# record) with one predicate method per controller action:
#
#   index?  show?  create?  new?  update?  edit?  destroy?
#
# Call `authorize(record)` at the top of a controller action. It looks up the
# policy for the record's class, builds it with the current user and the
# record, and calls the predicate matching the current action. A falsey result
# raises a 403; otherwise it returns the record. You can also pass an explicit
# action: `authorize(post, "update")`.
#
# Policies default to DENY — subclasses opt in by overriding the predicates
# they want to allow. See app/policies/user_policy.sl for a worked example.

class ApplicationPolicy
  user: Any
  record: Any

  new(context) {
    this.user = context["user"]
    this.record = context["record"]
  }

  def index?
    false
  end

  def show?
    false
  end

  def create?
    false
  end

  # `new?` mirrors `create?` and `edit?` mirrors `update?` by convention.
  def new?
    return this.send("create?")
  end

  def update?
    false
  end

  def edit?
    return this.send("update?")
  end

  def destroy?
    false
  end

  # Handy in subclasses: any signed-in user.
  def signed_in?
    return !this.user.nil?
  end
end

# Build the policy object for `record`. Denies (403) when no policy class
# exists, so a forgotten policy fails closed rather than open.
fn policy_for(record) {
  policy_class = const_get(record.class + "Policy")
  if policy_class.nil?
    forbidden("No policy class '" + record.class + "Policy'. Add app/policies/<model>_policy.sl")
  end
  return policy_class.new({ "user": current_user(), "record": record })
}

# Authorize `record` for the current action (or an explicit one). Returns the
# record when allowed; raises a 403 otherwise.
fn authorize(record, action = null) {
  act = action ?? current_action()
  act = "show" if act.blank?
  policy = policy_for(record)
  if !policy.send(act + "?")
    forbidden("Not authorized to " + act + " this " + record.class)
  end
  return record
}

# The signed-in user for the current request, or nil. Populated by the
# `load_current_user` middleware. Defined here (global scope) so controllers
# and policies can call it; views use the copy in app/helpers/auth_helper.sl.
fn current_user {
  return req["current_user"] rescue null
}

fn signed_in? {
  return !current_user().nil?
}
