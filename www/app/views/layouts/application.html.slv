<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Soli MVC</title>
    <meta name="description" content="Soli MVC - A modern, high-performance web framework with expressive syntax.">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet">

    <!-- Fuse.js for search -->
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0"></script>

    <link rel="stylesheet" href="<%= public_path("css/application.css") %>">
    <!-- live.js is not loaded here: pages with live roots lazy-load it on demand -->

    <style>
        body { font-family: 'Inter', sans-serif; }
        code, pre { font-family: 'JetBrains Mono', monospace; }
        .font-display { font-family: 'Bricolage Grotesque', 'Inter', sans-serif; }

        /* Glass navigation on warm near-black */
        .glass-nav {
            background: rgba(12, 10, 9, 0.82);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(250, 250, 249, 0.06);
        }

        /* Solar backdrop: warm stone base, one low sunrise glow */
        .hero-gradient {
            background-color: #0C0A09;
            background-image:
                radial-gradient(ellipse 75% 45% at 50% -15%, rgba(245, 158, 11, 0.13) 0%, transparent 60%),
                radial-gradient(ellipse 55% 35% at 85% 110%, rgba(251, 146, 60, 0.05) 0%, transparent 55%);
            background-attachment: fixed;
        }

        /* Premium button hover effects */
        .btn-glow {
            position: relative;
            overflow: hidden;
        }
        .btn-glow::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            transform: translateX(-100%);
            transition: transform 0.5s;
        }
        .btn-glow:hover::before {
            transform: translateX(100%);
        }

        /* Smooth scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
            background: rgba(245, 158, 11, 0.3);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(245, 158, 11, 0.5);
        }

        /* Scroll Reveal Animation */
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
        }
        .reveal-visible {
            opacity: 1;
            transform: translateY(0);
        }

        @media (prefers-reduced-motion: reduce) {
            .reveal-on-scroll {
                opacity: 1;
                transform: none;
                transition: none;
            }
            *, ::before, ::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        /* Mobile menu animation */
        .mobile-nav {
            display: none;
        }
        .mobile-nav.open {
            display: block;
        }
    </style>
</head>
<body class="bg-[#0C0A09] text-stone-100 flex flex-col min-h-full hero-gradient antialiased selection:bg-amber-500/40 selection:text-white">
    <!-- Navigation -->
    <nav class="glass-nav sticky top-0 z-50">
        <div class="px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex items-center gap-3 group">
                        <div class="relative">
                            <div class="absolute inset-0 bg-amber-500 rounded-full blur-lg opacity-40 group-hover:opacity-70 transition-opacity"></div>
                            <div class="relative w-9 h-9 rounded-full bg-[radial-gradient(circle_at_32%_28%,#FDE68A_0%,#F59E0B_55%,#C2620C_100%)] flex items-center justify-center font-bold text-stone-950 shadow-lg">
                                S
                            </div>
                        </div>
                        <span class="text-xl font-bold tracking-tight">
                            <span class="text-white">Soli</span>
                            <span class="text-stone-400 font-normal">MVC</span>
                        </span>
                    </a>
                </div>

                <!-- Desktop Navigation -->
                <div class="hidden lg:flex items-center gap-1">
                    <a href="/" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/5 transition-all">
                        Home
                    </a>
                    <a href="/docs" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/5 transition-all">
                        Documentation
                    </a>
                    <a href="/docs/blog" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/5 transition-all">
                        Blog
                    </a>
                    <button onclick="openSearchModal()" class="px-3 py-2 text-gray-400 hover:text-white rounded-lg hover:bg-white/5 transition-all">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </button>
                    <a href="https://github.com/solisoft/soli_lang" target="_blank" class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white rounded-lg hover:bg-white/5 transition-all flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                        GitHub
                    </a>
                    <div class="w-px h-6 bg-white/10 mx-2"></div>
                    <a href="/docs/introduction" class="btn-glow ml-2 inline-flex items-center gap-2 px-5 py-2 text-sm font-semibold text-stone-950 bg-amber-500 hover:bg-amber-400 rounded-lg transition-all shadow-lg shadow-amber-500/25 hover:shadow-amber-500/40">
                        Get Started
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                        </svg>
                    </a>
                </div>

                <!-- Mobile menu button -->
                <div class="lg:hidden flex items-center">
                    <button onclick="toggleMobileNav()" class="p-2 text-gray-400 hover:text-white transition-colors">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobileNav" class="mobile-nav lg:hidden absolute top-full left-0 right-0 bg-[#0C0A09]/95 backdrop-blur-xl border-b border-white/5">
            <div class="px-4 py-4 space-y-1">
                <a href="/" class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all">Home</a>
                <a href="/docs" class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all">Documentation</a>
                <a href="/docs/blog" class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all">Blog</a>
                <button onclick="openSearchModal()" class="w-full flex items-center gap-3 px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <span>Search</span>
                </button>
                <a href="https://github.com/solisoft/soli_lang" target="_blank" class="block px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all">GitHub</a>
                <div class="pt-2">
                    <a href="/docs/introduction" class="block px-4 py-3 text-center text-stone-950 bg-amber-500 hover:bg-amber-400 rounded-lg transition-all font-semibold">
                        Get Started
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow">
        <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-[#0C0A09]/80 backdrop-blur-xl mt-auto">
        <div class="py-12 px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
                <!-- Brand -->
                <div class="md:col-span-2">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-8 h-8 rounded-full bg-[radial-gradient(circle_at_32%_28%,#FDE68A_0%,#F59E0B_55%,#C2620C_100%)] flex items-center justify-center font-bold text-stone-950 text-sm">S</div>
                        <span class="font-bold text-lg text-white">Soli MVC</span>
                    </div>
                    <p class="text-stone-400 text-sm">
                        The whole framework in one binary &mdash; Ruby's expressiveness, Rust's speed, zero dependencies.
                    </p>
                </div>

                <!-- Links -->
                <div>
                    <h4 class="text-sm font-semibold text-white mb-4">Documentation</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/docs/introduction" class="text-gray-400 hover:text-white transition-colors">Introduction</a></li>
                        <li><a href="/docs/installation" class="text-gray-400 hover:text-white transition-colors">Installation</a></li>
                        <li><a href="/docs/routing" class="text-gray-400 hover:text-white transition-colors">Routing</a></li>
                        <li><a href="/docs/controllers" class="text-gray-400 hover:text-white transition-colors">Controllers</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-sm font-semibold text-white mb-4">Guides</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/docs/authentication" class="text-gray-400 hover:text-white transition-colors">Authentication</a></li>
                        <li><a href="/docs/sessions" class="text-gray-400 hover:text-white transition-colors">Sessions</a></li>
                        <li><a href="/docs/validation" class="text-gray-400 hover:text-white transition-colors">Validation</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-sm font-semibold text-white mb-4">Community</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="https://github.com/solisoft/soli_lang" target="_blank" class="text-gray-400 hover:text-white transition-colors">GitHub</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Discord</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Twitter</a></li>
                    </ul>
                </div>
            </div>

            <!-- Bottom -->
            <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
                <p class="text-sm text-gray-500">&copy; 2026 SoliLang. MIT License.</p>
                <div class="flex items-center gap-6">
                    <a href="#" class="text-gray-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                    </a>
                    <a href="#" class="text-gray-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" /></svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <%- render_partial("layouts/search_modal") %>

    <script>
    function toggleMobileNav() {
        document.getElementById('mobileNav').classList.toggle('open');
    }

    // Fetch latest release version from GitHub
    async function updateVersionBadge() {
        const versionBadge = document.getElementById('version-badge');
        if (!versionBadge) return;
        
        try {
            const response = await fetch('https://api.github.com/repos/solisoft/soli_lang/releases/latest');
            if (response.ok) {
                const data = await response.json();
                const version = data.tag_name?.replace('v', '') || '1.0';
                versionBadge.textContent = `Soli v${version} is here`;
            }
        } catch (e) {
            versionBadge.textContent = "Soli v1.0 Beta is here";
        }
    }

    // Page init. This inline script re-executes on every instant-nav <body>
    // swap (nav.js), while DOMContentLoaded only fires once per document — so
    // run directly instead of waiting on an event that may never come again.
    function initAppPage() {
        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('reveal-visible');
                    observer.unobserve(entry.target); // Only animate once
                }
            });
        }, { root: null, rootMargin: '0px', threshold: 0.1 });

        document.querySelectorAll('.reveal-on-scroll').forEach(el => {
            observer.observe(el);
        });

        updateVersionBadge();
    }

    initAppPage();

    // Bind document-level listeners once; the re-run would otherwise stack one
    // per visit. `soli:load` covers swap paths that don't re-run scripts,
    // `livereload:update` covers dev hot reloads.
    if (!window.__soliAppListenersBound) {
        window.__soliAppListenersBound = true;
        document.addEventListener('soli:load', initAppPage);
        document.addEventListener('livereload:update', initAppPage);
    }
    </script>

    <!-- HTMx + Alpine.js (Soli's default client stack — see /docs/core-concepts/client-interactivity) -->
    <script defer src="<%= public_path("js/htmx.min.js") %>"></script>
    <script defer src="<%= public_path("js/alpine.min.js") %>"></script>
</body>
</html>
