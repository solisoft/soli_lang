<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Soli MVC Documentation</title>
    <meta name="description" content="Documentation for Soli MVC Framework - Build modern web applications with elegance and performance.">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Highlight.js for syntax highlighting -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

    <!-- Fuse.js for search -->
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0"></script>

    <link rel="stylesheet" href="<%= public_path("css/application.css") %>">
    <style>
        body { font-family: 'Inter', sans-serif; }
        code, pre { font-family: 'JetBrains Mono', monospace; }

        /* Premium scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Page Transition */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        /* Premium Code block styling */
        pre {
            margin: 0 !important;
            padding: 0 !important;
            background: #0d1117 !important;
            border-radius: 0.5rem !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            position: relative;
            overflow: hidden !important;
        }

        /* Code block filename label */
        pre[data-filename]::before {
            content: attr(data-filename);
            display: flex;
            align-items: center;
            justify-content: center;
            height: 36px;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: #9ca3af;
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            font-weight: 500;
        }

        pre code, pre .hljs {
            padding: 1.25rem 1.5rem !important;
            font-size: 0.875rem !important;
            line-height: 1.7 !important;
            font-family: 'JetBrains Mono', monospace !important;
            display: block;
            background: transparent !important;
        }

        /* Copy-to-clipboard button (injected into every code block) */
        .code-copy-btn {
            position: absolute;
            top: 6px;
            right: 8px;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.25rem 0.55rem;
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            color: #9ca3af;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.375rem;
            cursor: pointer;
            opacity: 0;
            transition: opacity 0.15s ease, color 0.15s ease, background 0.15s ease;
        }

        pre:hover .code-copy-btn { opacity: 1; }
        .code-copy-btn:hover { color: #fff; background: rgba(255, 255, 255, 0.12); }
        .code-copy-btn.copied { color: #34d399; border-color: rgba(52, 211, 153, 0.4); }
        .code-copy-btn svg { width: 0.85rem; height: 0.85rem; }

        /* Inline code styling */
        :not(pre) > code {
            background: rgba(99, 102, 241, 0.1);
            color: #a5b4fc;
            padding: 0.2rem 0.4rem;
            border-radius: 0.375rem;
            font-size: 0.85em;
            font-weight: 500;
            border: 1px solid rgba(99, 102, 241, 0.2);
        }


        /* Prose customization - full width */
        .prose-docs {
            max-width: none !important;
        }

        .prose-docs :where(code):not(:where([class~="not-prose"] *))::before { content: "" !important; }
        .prose-docs :where(code):not(:where([class~="not-prose"] *))::after { content: "" !important; }

        .prose-docs h1 {
            color: white;
            font-weight: 800;
            font-size: 2.5rem;
            letter-spacing: -0.025em;
            margin-bottom: 1.5rem;
        }

        .prose-docs h2 {
            color: white;
            font-weight: 700;
            font-size: 1.75rem;
            margin-top: 3.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            letter-spacing: -0.015em;
            scroll-margin-top: 5rem;
        }

        .prose-docs h3 {
            color: #e5e7eb;
            font-weight: 600;
            font-size: 1.25rem;
            margin-top: 2.5rem;
            scroll-margin-top: 5rem;
        }

        /* Right-rail "On this page" TOC */
        .toc a {
            display: block;
            padding: 0.3rem 0;
            color: rgba(148, 163, 184, 0.85);
            font-size: 0.83rem;
            line-height: 1.4;
            transition: color .15s ease;
            text-decoration: none;
            border-bottom: 0;
        }
        .toc a:hover { color: #fff; }
        .toc a.is-current { color: #c7d2fe; }
        .toc a.is-current::before {
            content: "● ";
            color: #818cf8;
            font-size: 0.6em;
            vertical-align: middle;
            margin-right: 0.25rem;
        }

        .prose-docs p { color: #9ca3af; line-height: 1.8; margin-bottom: 1.5rem; }
        .prose-docs ul, .prose-docs ol { color: #9ca3af; margin-bottom: 1.5rem; }
        .prose-docs li { margin-top: 0.5rem; margin-bottom: 0.5rem; }

        .prose-docs a {
            color: #818cf8;
            text-decoration: none;
            border-bottom: 1px solid transparent;
            transition: all 0.2s;
        }
        .prose-docs a:hover {
            color: #a5b4fc;
            border-bottom-color: #a5b4fc;
        }

        .prose-docs strong { color: white; font-weight: 600; }

        .prose-docs blockquote {
            border-left: 3px solid #6366f1;
            background: linear-gradient(to right, rgba(99, 102, 241, 0.1), transparent);
            padding: 1rem 1.5rem;
            border-radius: 0.5rem;
            margin: 2rem 0;
            font-style: normal;
        }
        .prose-docs blockquote p { color: #c4b5fd; margin: 0; }

        /* Sidebar animation */
        .sidebar-link {
            position: relative;
            transition: all 0.2s ease;
        }

        .sidebar-link:hover {
            background: rgba(255, 255, 255, 0.05);
            color: white;
        }

        .sidebar-link.active {
            background: rgba(99, 102, 241, 0.1);
            color: #818cf8;
            font-weight: 500;
        }

        .sidebar-link.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: #6366f1;
            border-radius: 3px 0 0 3px;
            box-shadow: 2px 0 10px rgba(99, 102, 241, 0.5);
        }

        /* Sticky Haders */
        header.sticky-glass {
            background: rgba(3, 7, 18, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* Mobile menu */
        .mobile-menu {
            transform: translateX(-100%);
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .mobile-menu.open {
            transform: translateX(0);
        }
    </style>
</head>
<body class="bg-gray-950 text-gray-300 antialiased h-full">
    <%- render_partial("layouts/search_modal") %>

    <!-- Mobile Header -->
    <header class="lg:hidden fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 h-16 border-b border-white/5 bg-gray-950/95 backdrop-blur-xl">
        <div class="flex items-center gap-3">
            <button onclick="toggleMobileMenu()" class="p-2 -ml-2 text-gray-400 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-bold text-white text-sm">S</div>
                <span class="font-semibold text-white">Soli Docs</span>
            </div>
        </div>
        <button onclick="openSearchModal()" class="p-2 text-gray-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </button>
    </header>

    <!-- Mobile Menu Overlay -->
    <div id="mobileMenuOverlay" class="lg:hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden" onclick="toggleMobileMenu()"></div>

    <!-- Mobile Sidebar -->
    <aside id="mobileSidebar" class="mobile-menu lg:hidden fixed top-16 left-0 bottom-0 w-72 z-40 bg-gray-950 border-r border-white/5 overflow-y-auto">
        <div class="p-6">
            <nav class="space-y-6">
                <%- render_partial("layouts/docs_nav") %>
            </nav>
        </div>
    </aside>

    <div class="flex h-full">
        <!-- Desktop Sidebar -->
        <aside class="hidden lg:flex lg:flex-col w-72 border-r border-white/5 bg-gray-950/50 h-screen sticky top-0">
            <!-- Header -->
            <div class="flex items-center gap-3 px-6 h-16 border-b border-white/5 flex-shrink-0">
                <a href="/" class="flex items-center gap-3 group">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-bold text-white shadow-lg shadow-indigo-500/25 group-hover:shadow-indigo-500/40 transition-shadow">S</div>
                    <span class="font-bold text-lg text-white tracking-tight">Soli MVC</span>
                </a>
            </div>

            <!-- Search Button -->
            <div class="px-4 py-3 border-b border-white/5">
                <button onclick="openSearchModal()" class="w-full flex items-center gap-3 px-3 py-2 text-sm text-gray-400 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <span>Search docs...</span>
                    <kbd class="ml-auto px-1.5 py-0.5 text-xs bg-white/10 rounded">Ctrl+K</kbd>
                </button>
            </div>

            <!-- Navigation -->
            <nav id="desktopNav" class="flex-1 overflow-y-auto py-6 px-4">
                <div class="space-y-6">
                    <%- render_partial("layouts/docs_nav") %>
                </div>
            </nav>

            <!-- Footer Links -->
            <div class="px-6 py-4 border-t border-white/5 flex-shrink-0">
                <div class="flex items-center justify-between">
                    <a href="https://github.com/solisoft/soli_lang" target="_blank" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                        GitHub
                    </a>
                    <span class="text-xs text-gray-600">v0.1.0</span>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 min-w-0 lg:h-screen lg:overflow-y-auto">
            <!-- Top bar for desktop -->
            <header class="hidden lg:flex items-center justify-between h-16 px-8 sticky-glass sticky top-0 z-10">
                <div class="flex items-center gap-4">
                    <nav class="flex items-center gap-2 text-sm">
                        <a href="/" class="text-gray-400 hover:text-white transition-colors">Home</a>
                        <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        <% if defined("breadcrumb_href") and breadcrumb_href != "" %>
                        <a href="<%= breadcrumb_href %>" class="text-gray-400 hover:text-white transition-colors">Docs</a>
                        <% else %>
                        <span class="text-gray-400">Docs</span>
                        <% end %>
                        <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        <span class="text-white font-medium"><%= title %></span>
                    </nav>
                </div>
                <div class="flex items-center gap-4">
                    <a href="https://github.com/solisoft/soli_lang" target="_blank" class="text-gray-400 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.48 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
                    </a>
                </div>
            </header>

            <!-- Content Area -->
            <div class="px-4 py-8 lg:px-8 lg:py-12 pt-20 lg:pt-12">
                <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_220px] xl:gap-12">
                    <div class="min-w-0">
                        <article id="doc-article" class="prose prose-invert max-w-none animate-fade-in prose-docs">
                            <!-- Two nested wrappers absorb up to 2 stray </div> tags from
                                 malformed page content so the layout's column structure
                                 stays intact even when an individual page has mismatched
                                 tags. -->
                            <div><div>
                                <%= yield %>
                            </div></div>
                        </article>

                        <!-- Footer -->
                        <footer class="mt-16 pt-8 border-t border-white/5">
                            <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm">
                                <p class="text-gray-500">&copy; 2026 SoliLang. MIT License.</p>
                                <a href="https://github.com/solisoft/soli_lang" target="_blank" class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                    Edit this page on GitHub
                                </a>
                            </div>
                        </footer>
                    </div>

                    <!-- Right rail: on-this-page TOC -->
                    <aside class="hidden xl:block">
                        <div class="sticky top-20">
                            <p class="text-[10px] font-mono tracking-[0.22em] uppercase text-gray-500 mb-3">On this page</p>
                            <nav id="page-toc" class="toc border-l border-white/10 pl-4"></nav>
                        </div>
                    </aside>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script>
    function toggleMobileMenu() {
        const sidebar = document.getElementById('mobileSidebar');
        const overlay = document.getElementById('mobileMenuOverlay');
        const isOpening = !sidebar.classList.contains('open');

        sidebar.classList.toggle('open');
        overlay.classList.toggle('hidden');
        document.body.classList.toggle('overflow-hidden');

        // Scroll to active item when opening mobile menu
        if (isOpening) {
            const activeLink = sidebar.querySelector('.sidebar-link.active');
            if (activeLink) {
                setTimeout(() => {
                    const sidebarRect = sidebar.getBoundingClientRect();
                    const linkRect = activeLink.getBoundingClientRect();
                    const offset = linkRect.top - sidebarRect.top - (sidebarRect.height / 2) + (linkRect.height / 2);
                    sidebar.scrollTop = offset;
                }, 100);
            }
        }
    }

    // SoliLang language definition for highlight.js
    hljs.registerLanguage('soli', function() {
        return {
            name: 'SoliLang',
            aliases: ['soli'],
            keywords: {
                keyword: 'def fn if then else elsif end return let for in while do break continue class extends < static this super new import use as try catch finally throw export const match',
                literal: 'null nil true false',
                built_in: 'print println datetime now hash_password validate_token redirect error json_encode json_decode render get post put patch delete resources scope middleware'
            },
            contains: [
                hljs.COMMENT('//', '$'),
                hljs.COMMENT('#', '$'),
                hljs.COMMENT('/\\*', '\\*/'),
                {
                    className: 'string',
                    begin: '"',
                    end: '"',
                    contains: [hljs.BACKSLASH_ESCAPE]
                },
                {
                    className: 'number',
                    begin: '-?\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b',
                    relevance: 0
                },
                {
                    className: 'title.function',
                    begin: '(?:def|fn)\\s+[a-zA-Z_][a-zA-Z0-9_]*',
                    relevance: 10
                },
                {
                    className: 'title.function',
                    begin: '[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()',
                    relevance: 0
                },
                {
                    className: 'type',
                    begin: ':\\s*(Any|String|Int|Float|Bool|Array|Hash|Object|Request|Response)',
                    relevance: 2
                }
            ]
        };
    });

    document.addEventListener('DOMContentLoaded', function() {
        initHighlighting();
        addCopyButtons();
        scrollToActiveMenuItem();
        buildOnThisPage();
    });

    document.addEventListener('livereload:update', function() {
        initHighlighting();
        addCopyButtons();
        buildOnThisPage();
    });

    // Inject a copy-to-clipboard button into every code block. Idempotent so
    // it can run again after livereload re-injects the article body.
    function addCopyButtons() {
        const copyIcon = '<svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m11.25 5.5H16.5a1.125 1.125 0 01-1.125-1.125v-3.5m3.375 4.625h-3.375"/></svg>';

        document.querySelectorAll('pre').forEach(function(pre) {
            if (pre.querySelector('.code-copy-btn')) return;
            const code = pre.querySelector('code');
            if (!code) return;

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'code-copy-btn';
            btn.setAttribute('aria-label', 'Copy code to clipboard');
            btn.innerHTML = copyIcon + '<span>Copy</span>';

            btn.addEventListener('click', function() {
                const text = code.textContent || '';
                navigator.clipboard.writeText(text).then(function() {
                    btn.classList.add('copied');
                    btn.querySelector('span').textContent = 'Copied!';
                    setTimeout(function() {
                        btn.classList.remove('copied');
                        btn.querySelector('span').textContent = 'Copy';
                    }, 1800);
                });
            });

            pre.appendChild(btn);
        });
    }

    // Holds the current observer so we can disconnect it before rebuilding
    // (livereload re-injects the article body, leaving the old observer
    // pointing at detached nodes).
    let __tocObserver = null;

    function buildOnThisPage() {
        const article = document.getElementById('doc-article');
        const toc = document.getElementById('page-toc');
        if (!article || !toc) return;

        const slug = function(s) {
            return s.toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-|-$/g, '')
                .slice(0, 60);
        };

        const headings = Array.from(article.querySelectorAll('h2'));
        toc.innerHTML = '';

        if (__tocObserver) { __tocObserver.disconnect(); __tocObserver = null; }

        if (headings.length === 0) {
            toc.innerHTML = '<p class="text-[12.5px] text-gray-500 italic">No subsections.</p>';
            return;
        }

        const seen = new Set();
        const links = new Map();
        headings.forEach(function(h) {
            const text = (h.textContent || '').replace(/\s+/g, ' ').trim();
            if (!text) return;

            let id = h.id;
            if (!id) {
                id = slug(text);
                let n = 1;
                while (seen.has(id)) { id = slug(text) + '-' + (++n); }
                h.id = id;
            }
            seen.add(id);

            const a = document.createElement('a');
            a.href = '#' + id;
            a.textContent = text;
            toc.appendChild(a);
            links.set(id, a);
        });

        // Scope the observer to the scrolling <main>, not the viewport — the
        // article lives inside `lg:h-screen lg:overflow-y-auto`.
        const scrollRoot = document.querySelector('main.lg\\:overflow-y-auto') || null;
        __tocObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
                if (e.isIntersecting) {
                    const id = e.target.id;
                    links.forEach(function(a) { a.classList.remove('is-current'); });
                    const cur = links.get(id);
                    if (cur) cur.classList.add('is-current');
                }
            });
        }, { root: scrollRoot, rootMargin: '-20% 0px -70% 0px', threshold: 0 });

        headings.forEach(function(h) { __tocObserver.observe(h); });
    }

    function scrollToActiveMenuItem() {
        const currentPath = window.location.pathname;

        // Find and activate links matching current URL in both sidebars
        document.querySelectorAll('.sidebar-link').forEach(link => {
            link.classList.remove('active', 'bg-indigo-500/10', 'text-indigo-400', 'font-medium');
            link.classList.add('text-gray-400', 'hover:bg-white/5', 'hover:text-white');

            if (link.getAttribute('href') === currentPath) {
                link.classList.add('active', 'bg-indigo-500/10', 'text-indigo-400', 'font-medium');
                link.classList.remove('text-gray-400');
            }
        });

        // Scroll desktop nav to active item
        const desktopNav = document.getElementById('desktopNav');
        if (desktopNav) {
            const activeLink = desktopNav.querySelector('.sidebar-link.active');
            if (activeLink) {
                setTimeout(() => {
                    const linkTop = activeLink.offsetTop;
                    const navHeight = desktopNav.clientHeight;
                    desktopNav.scrollTop = linkTop - (navHeight / 2);
                }, 100);
            }
        }
    }

    function initHighlighting() {
        document.querySelectorAll('code.language-erb').forEach(function(block) {
            block.classList.remove('language-erb');
            block.classList.add('language-xml');
        });

        document.querySelectorAll('code[data-highlighted]').forEach(function(block) {
            block.removeAttribute('data-highlighted');
        });

        hljs.highlightAll();
    }
    </script>
</body>
</html>
