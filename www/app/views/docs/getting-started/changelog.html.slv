    <!-- Click-to-zoom lightbox for the diagrams (full viewport) -->
    <div id="cl-lightbox" class="fixed inset-0 w-screen h-screen z-[9999] hidden items-center justify-center bg-black/85 backdrop-blur-sm p-4 sm:p-10 cursor-zoom-out" aria-hidden="true">
        <img id="cl-lightbox-img" src="" alt="" class="max-h-[92vh] max-w-full w-auto rounded-lg border border-white/10 shadow-2xl bg-[#0b0d0f]">
        <button id="cl-lightbox-close" type="button" aria-label="Close" class="absolute top-4 right-5 text-3xl leading-none text-gray-300 hover:text-white">&times;</button>
    </div>
    <script>
    (function () {
        var box = document.getElementById('cl-lightbox');
        if (!box) return;
        // Reparent to <body> so `position: fixed` is anchored to the viewport
        // even if an ancestor establishes a containing block (transform/filter);
        // on this long page that keeps the overlay centered on screen wherever
        // you've scrolled. De-dupe any copy a previous instant-nav visit moved.
        document.querySelectorAll('#cl-lightbox').forEach(function (n) {
            if (n !== box && n.parentElement === document.body) n.remove();
        });
        if (box.parentElement !== document.body) document.body.appendChild(box);
        var img = document.getElementById('cl-lightbox-img');
        if (!img) return;
        function open(src, alt) {
            img.src = src;
            img.alt = alt || '';
            box.classList.remove('hidden');
            box.classList.add('flex');
            box.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }
        function close() {
            box.classList.add('hidden');
            box.classList.remove('flex');
            box.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            img.src = '';
        }
        document.querySelectorAll('.changelog-zoom').forEach(function (el) {
            el.addEventListener('click', function () { open(el.getAttribute('src'), el.getAttribute('alt')); });
            el.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(el.getAttribute('src'), el.getAttribute('alt')); }
            });
        });
        box.addEventListener('click', close); // click backdrop (or image) closes
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
    })();
    </script>
</div>
