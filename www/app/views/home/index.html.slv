<!-- Live view demo -->
<section id="live-view-demo" class="relative py-20 sm:py-28 bg-white/[0.02] border-y border-white/[0.04]">
    <div class="container mx-auto max-w-6xl px-6 lg:px-8">
        <div class="mb-12 reveal-on-scroll">
            <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-5xl">This counter is live, right now</h2>
            <p class="mt-5 text-lg text-stone-400 max-w-3xl">
                A server-rendered reactive component over a WebSocket &mdash; no JavaScript written,
                ~2&nbsp;KB client, diff-based updates. Click it.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="reveal-on-scroll">
                <div class="rounded-xl bg-[#171412] ring-1 ring-white/[0.06] overflow-hidden">
                    <div class="px-4 py-2.5 bg-white/[0.04] border-b border-white/[0.06]">
                        <span class="text-xs font-mono text-stone-400">Live demo &middot; /live/socket/counter</span>
                    </div>
                    <div class="p-8" id="live-counter-container" data-live-root data-liveview-manual data-liveview-url="/live/socket/counter">
                        <div class="text-center">
                            <div class="text-6xl font-bold text-white mb-8">...</div>
                            <p class="text-sm text-stone-500">Connecting...</p>
                        </div>
                    </div>
                </div>
                <div class="mt-6 grid grid-cols-3 gap-4">
                    <div class="text-center p-3 rounded-xl bg-white/[0.03] ring-1 ring-white/[0.06]">
                        <div class="text-lg font-bold text-amber-400">0 JS</div>
                        <div class="text-xs text-stone-500">Written</div>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-white/[0.03] ring-1 ring-white/[0.06]">
                        <div class="text-lg font-bold text-amber-400">Diff</div>
                        <div class="text-xs text-stone-500">Updates</div>
                    </div>
                    <div class="text-center p-3 rounded-xl bg-white/[0.03] ring-1 ring-white/[0.06]">
                        <div class="text-lg font-bold text-amber-400">~2KB</div>
                        <div class="text-xs text-stone-500">Client</div>
                    </div>
                </div>
            </div>

            <div class="reveal-on-scroll" style="transition-delay: 100ms;">
                <div class="rounded-xl bg-[#171412] ring-1 ring-white/[0.06] overflow-hidden">
                    <div class="px-4 py-2.5 bg-white/[0.04] border-b border-white/[0.06]">
                        <span class="text-xs font-mono text-stone-400">app/views/live/counter.sliv</span>
                    </div>
                    <div class="px-5 py-4 overflow-x-auto">
<pre class="text-sm leading-7"><code><span class="text-stone-500">&lt;!-- That's the whole component. --&gt;</span>
<span class="text-stone-400">&lt;div</span> <span class="text-orange-300">class=</span><span class="text-stone-100">"counter"</span><span class="text-stone-400">&gt;</span>
  <span class="text-stone-400">&lt;h2&gt;</span><span class="text-orange-200">@count</span><span class="text-stone-400">&lt;/h2&gt;</span>
  <span class="text-stone-400">&lt;button</span> <span class="text-orange-300">soli-click=</span><span class="text-stone-100">"decrement"</span><span class="text-stone-400">&gt;</span>-<span class="text-stone-400">&lt;/button&gt;</span>
  <span class="text-stone-400">&lt;button</span> <span class="text-orange-300">soli-click=</span><span class="text-stone-100">"increment"</span><span class="text-stone-400">&gt;</span>+<span class="text-stone-400">&lt;/button&gt;</span>
<span class="text-stone-400">&lt;/div&gt;</span></code></pre>
                    </div>
                </div>
                <div class="mt-6 text-sm text-stone-500">
                    The server holds the state; the client patches the DOM.
                    A second live demo &mdash; a server clock pushing 20 updates a second &mdash; runs in the
                    <a href="/docs/core-concepts/liveview" class="text-amber-400 hover:text-amber-300 transition-colors">LiveView docs</a>.
                </div>
            </div>
        </div>
    </div>
</section>

