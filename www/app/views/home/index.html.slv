</section>

<script>
    // Copy the "soli new" command from the hero chip.
    function copyNewAppCmd(btn) {
        const cmd = 'soli new blog && soli serve blog';
        navigator.clipboard.writeText(cmd).then(() => {
            const icon = btn.querySelector('[data-copy-icon]');
            if (!icon) return;
            icon.classList.add('text-amber-400');
            btn.classList.add('ring-amber-500/40');
            setTimeout(() => {
                icon.classList.remove('text-amber-400');
                btn.classList.remove('ring-amber-500/40');
            }, 1200);
        });
    }

    // Typing animation for the terminal demo.
    (function () {
        const typeElements = document.querySelectorAll('.type-animation');

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const el = entry.target;
                    if (!el.dataset.typed) {
                        el.dataset.typed = "true";
                        typeText(el);
                    }
                }
            });
        }, { threshold: 0.5 });

        typeElements.forEach(el => observer.observe(el));

        function typeText(element) {
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                element.classList.remove('invisible');
                return;
            }
            const html = element.innerHTML;
            element.innerHTML = '';
            element.classList.remove('invisible');

            let i = 0;
            let tag = false;
            let currentHtml = '';

            function type() {
                if (i < html.length) {
                    let char = html.charAt(i);
                    if (char === '<') tag = true;
                    else if (char === '>') tag = false;

                    currentHtml += char;
                    element.innerHTML = currentHtml;
                    i++;
                    if (tag || char === ' ') {
                        type();
                    } else {
                        setTimeout(type, Math.random() * 20 + 10);
                    }
                }
            }
            type();
        }
    })();

    // Connect LiveView roots. live.js only auto-connects on DOMContentLoaded,
    // which never re-fires after an instant-nav <body> swap — so roots are
    // marked data-liveview-manual and connected by hand here, loading live.js
    // on demand when the swap came from a layout that doesn't include it.
    (function () {
        function connectLiveRoots() {
            document.querySelectorAll('[data-liveview-url][data-liveview-manual]').forEach(function (el) {
                if (el.dataset.lvConnected) return;
                el.dataset.lvConnected = '1';
                let url = el.getAttribute('data-liveview-url');
                if (url.startsWith('/')) {
                    const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
                    url = protocol + '//' + location.host + url;
                }
                window.live(url, { rootElement: el });
            });
        }

        if (window.live) {
            connectLiveRoots();
            return;
        }
        let loader = document.getElementById('__livejs-loader');
        if (!loader) {
            loader = document.createElement('script');
            loader.id = '__livejs-loader';
            loader.src = '/js/live.js';
            document.head.appendChild(loader);
        }
        loader.addEventListener('load', connectLiveRoots, { once: true });
    })();
</script>
