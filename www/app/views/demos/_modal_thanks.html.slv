<div class="text-center py-6">
    <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-300 mb-3">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    </div>
    <p class="text-white font-medium">Thanks, <%= name %>.</p>
    <p class="text-sm text-gray-500 mt-1">The form was submitted and the panel swapped &mdash; all without leaving the modal.</p>
</div>
