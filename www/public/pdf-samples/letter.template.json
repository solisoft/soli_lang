{
  "fonts": ["titillium"],
  "footer": [
    { "type": "paragraph", "value": "${company.name} — ${company.email}", "options": { "alignment": "center", "fontSize": 8 } }
  ],
  "content": [
    { "type": "paragraph", "value": "${company.name}", "options": { "fontSize": 22, "fontWeight": "bold" } },
    { "type": "paragraph", "value": "${company.tagline}", "options": { "fontSize": 11 } },
    { "type": "move", "y": 8 },
    { "type": "paragraph", "value": "${letter.place_date}", "options": { "alignment": "right", "fontSize": 10 } },
    { "type": "move", "y": 18 },
    { "type": "paragraph", "value": "${letter.greeting}", "options": { "fontSize": 11 } },
    { "type": "move", "y": 10 },
    { "type": "paragraph", "value": "${letter.body1}", "options": { "fontSize": 11 } },
    { "type": "move", "y": 8 },
    { "type": "paragraph", "value": "${letter.body2}", "options": { "fontSize": 11 } },
    { "type": "move", "y": 10 },
    { "type": "paragraph", "options": { "fontSize": 11 }, "spans": [
      { "text": "P.S. Inline rich text — run " },
      { "text": "soli serve .", "mono": true },
      { "text": " to preview, read the " },
      { "text": "style guide", "italic": true },
      { "text": " for the " },
      { "text": "details", "fontWeight": "bold" },
      { "text": ", or visit " },
      { "text": "our docs", "link": "https://soli.example/docs", "color": "1D4ED8" },
      { "text": "." }
    ] },
    { "type": "move", "y": 16 },
    { "type": "paragraph", "value": "${letter.closing}", "options": { "fontSize": 11 } },
    { "type": "move", "y": 6 },
    { "type": "paragraph", "value": "${letter.signature}", "options": { "fontSize": 11, "fontWeight": "bold" } }
  ]
}
